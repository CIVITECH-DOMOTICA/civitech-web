    "@angular/platform-browser-dynamic": "^16.2.0",
    "@angular/platform-server": "^16.2.12",
    "@angular/router": "^16.2.0",
    "@emailjs/browser": "^4.4.1",
    "@nguniversal/express-engine": "^16.2.0",
